<EndStoreConnectionParms>
	<!-- These parms define the iSeries Access and the MQ queue being -->
      <!-- used for a controlled end for a store connection, either the TRANS -->
      <!-- or CLOSE depending on the parm sent in. -->

	<!--COMMON SYSTEM PARAMETERS-->
	<system_parameters>
		<log4j_config_path>/retail/applications/vbsinterface/properties/log4j/log4j_EndStoreCon.properties</log4j_config_path>
	</system_parameters>
	
	<!--ISERIES CONNECTION PARAMETERS-->
	<iseries_parameters>
		<host>SYSTHREE</host>
		<user>VBPROCESS</user>
		<password>VBPROCESS</password>
	</iseries_parameters>

  <!--MQ QUEUE MANAGER PARAMETERS-->
  <queue_manager>
    <host>SYSTHREE</host> 
    <queue_manager_name>SYS3.3</queue_manager_name> 
    <user>vbprocess</user> 
    <password>vbprocess</password> 
    <mq_channel>SYSTEM.ADMIN.SVRCONN</mq_channel> 
    <mq_port>1416</mq_port> 
  </queue_manager>

	<!--VENDOR SETTLEMENT SOURCE QUEUE PARAMETERS-->
	<source_queue>
		<queue_mq_wait_interval_milliseconds>5000</queue_mq_wait_interval_milliseconds>
   		<end_store_mq_priority>9</end_store_mq_priority>
	</source_queue>
</EndStoreConnectionParms>
