	<TransactionsPerFile>1500</TransactionsPerFile>
	<!-- If Local = Y then we don't try to send the file to BeanStore after creating it. Change to  N to send. -->
	<Local>Y</Local>
	<!-- BeanStore requires files to arrive at least one-->
	<!-- minute apart or they may not be processed in -->
	<!-- the sequence they were received -->
	<SleepBeforeSendXML>1000</SleepBeforeSendXML>
	<!-- CustomerInformationCollection = Y sets information capture on for fields in Beanstore -->
	<CustomerInformationCollection>N</CustomerInformationCollection>
	<Debugging>Y</Debugging>
	<CentralServerUserID></CentralServerUserID>
	<CentralServerPassword></CentralServerPassword>
