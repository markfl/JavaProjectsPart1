<VendorSettlementParms>
	<!-- These parms define the iSeries Access for the DDM Data Queue --> 
      <!-- and the MQ queue being used for the Vendor Settlement -->

	<!--COMMON SYSTEM PARAMETERS-->
	<system_parameters>
		<log4j_config_path>retail/applications/vbsinterface/properties/log4j/log4j_VendorSettlement.properties</log4j_config_path>
	</system_parameters>
	
	<!--ISERIES CONNECTION PARAMETERS-->
	<iseries_parameters>
		<host>SYSTHREE</host>
		<user>GCPROCESS</user>
		<password>GCPROCESS</password>
	   	<ddm_dtaq>/QSYS.LIB/BASS6LIB.LIB/SCGCS01U.DTAQ</ddm_dtaq>
	</iseries_parameters>

	<!--MQ QUEUE MANAGER PARAMETERS-->
	<queue_manager>
		<host>SYSTHREE</host>
		<queue_manager_name>SYS3.4</queue_manager_name>
		<user>GCPROCESS</user>
		<password>GCPROCESS</password>
		<mq_channel>SYSTEM.ADMIN.SVRCONN</mq_channel>
		<mq_port>1417</mq_port>
	</queue_manager>

	<!--VENDOR SETTLEMENT SOURCE QUEUE PARAMETERS-->
	<source_queue>
		<queue_name>AS4.LA.OLTP.SETTLEMENT</queue_name>
		<queue_mq_wait_interval_milliseconds>5000</queue_mq_wait_interval_milliseconds>
		<vndr_stlmnt_mq_priority>9</vndr_stlmnt_mq_priority>
	</source_queue>
</VendorSettlementParms>

