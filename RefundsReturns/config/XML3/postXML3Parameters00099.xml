	<!-- The Legacy process is always the process being conditioned as parallel and thus being turned 'off' when   -->
	<!--   parallel is complete.                                                                                   -->
	<!-- Therefore entity_indicator should always start out as 'on' and isParallel will default to 'off' if no     -->
	<!--   entry exists.                                                                                           -->
